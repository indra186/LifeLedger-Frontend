<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">
    <action
        android:id="@+id/action_global_transactionDetailFragment"
        app:destination="@id/transactionDetailFragment" />

    <!-- Onboarding -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.lifeledger.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_introFragment"
            app:destination="@id/introFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashFragment_to_dashboardFragment"
            app:destination="@id/nav_dashboard"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/introFragment"
        android:name="com.example.lifeledger.IntroFragment"
        android:label="Intro"
        tools:layout="@layout/fragment_intro">
        <action
            android:id="@+id/action_introFragment_to_signupFragment"
            app:destination="@id/signupFragment"
            app:popUpTo="@id/introFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_introFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/introFragment"
            app:popUpToInclusive="true" />
    </fragment>
    
    <fragment
        android:id="@+id/signupFragment"
        android:name="com.example.lifeledger.SignupFragment"
        android:label="Sign Up"
        tools:layout="@layout/fragment_signup">
        <action
            android:id="@+id/action_signupFragment_to_otpFragment"
            app:destination="@id/otpFragment" />
        <action
            android:id="@+id/action_signupFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.lifeledger.LoginFragment"
        android:label="Log In"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/nav_dashboard"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_signupFragment"
            app:destination="@id/signupFragment" />
    </fragment>

    <fragment
        android:id="@+id/otpFragment"
        android:name="com.example.lifeledger.OtpFragment"
        android:label="OTP"
        tools:layout="@layout/fragment_otp">
        <action
            android:id="@+id/action_otpFragment_to_dashboardFragment"
            app:destination="@id/nav_dashboard"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_otp_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/otpFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.example.lifeledger.ForgotPasswordFragment"
        android:label="ForgotPasswordFragment" />
    <fragment
        android:id="@+id/changePasswordFragment"
        android:name="com.example.lifeledger.ChangePasswordFragment"
        android:label="Change Password"
        tools:layout="@layout/fragment_change_password"/>

    <fragment
        android:id="@+id/editEmailFragment"
        android:name="com.example.lifeledger.EditEmailFragment"
        android:label="Edit Email"
        tools:layout="@layout/fragment_edit_email"/>

    <fragment
        android:id="@+id/deleteAccountFragment"
        android:name="com.example.lifeledger.DeleteAccountFragment"
        android:label="Delete Account"
        tools:layout="@layout/fragment_delete_account"/>

    <!-- Dashboard -->
    <fragment
        android:id="@+id/nav_dashboard"
        android:name="com.example.lifeledger.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboardFragment_to_notificationsFragment"
            app:destination="@id/notificationsFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_goalsFragment"
            app:destination="@id/goalsFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_activityFeedFragment"
            app:destination="@id/activityFeedFragment" />
    </fragment>

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.example.lifeledger.NotificationsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications" />

    <!-- Finance -->
    <fragment
        android:id="@+id/nav_finance"
        android:name="com.example.lifeledger.FinanceFragment"
        android:label="Finance"
        tools:layout="@layout/fragment_finance">
        <action
            android:id="@+id/action_financeFragment_to_transactionsFragment"
            app:destination="@id/transactionsFragment" />
        <action
            android:id="@+id/action_financeFragment_to_budgetsFragment"
            app:destination="@id/budgetsFragment" />

        <action
            android:id="@+id/action_financeFragment_to_accountsFragment"
            app:destination="@id/accountsFragment" />

        <action
            android:id="@+id/action_financeFragment_to_monthlyReportFragment"
            app:destination="@id/monthlyReportFragment" />
    </fragment>

    <fragment
        android:id="@+id/accountsFragment"
        android:name="com.example.lifeledger.AccountsFragment"
        android:label="Accounts"
        tools:layout="@layout/fragment_accounts">
        <action
            android:id="@+id/action_accountsFragment_to_addAccountFragment"
            app:destination="@id/addAccountFragment" />
    </fragment>
    
    <fragment
        android:id="@+id/addAccountFragment"
        android:name="com.example.lifeledger.AddAccountFragment"
        android:label="Add Account"
        tools:layout="@layout/fragment_add_account" />

    <fragment
        android:id="@+id/transactionsFragment"
        android:name="com.example.lifeledger.TransactionsFragment"
        android:label="Transactions"
        tools:layout="@layout/fragment_transactions">
        <action
            android:id="@+id/action_transactionsFragment_to_addTransactionFragment"
            app:destination="@id/addTransactionFragment" />
        <action
            android:id="@+id/action_transactionsFragment_to_transactionDetailFragment"
            app:destination="@id/transactionDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/transactionDetailFragment"
        android:name="com.example.lifeledger.TransactionDetailFragment"
        android:label="Transaction Detail"
        tools:layout="@layout/fragment_transaction_detail">

        <argument
            android:name="tx_id"
            app:argType="integer" />

    </fragment>

    <fragment
        android:id="@+id/todayHabitsFragment"
        android:name="com.example.lifeledger.TodayHabitsFragment"
        android:label="Today's Habits"
        tools:layout="@layout/fragment_today_habits" />
    <fragment
        android:id="@+id/addTransactionFragment"
        android:name="com.example.lifeledger.AddTransactionFragment"
        android:label="Add Transaction"
        tools:layout="@layout/fragment_add_transaction_new" />

    <fragment
        android:id="@+id/budgetsFragment"
        android:name="com.example.lifeledger.BudgetsFragment"
        android:label="Budgets"
        tools:layout="@layout/fragment_budgets">
        <action
            android:id="@+id/action_budgetsFragment_to_createBudgetFragment"
            app:destination="@id/createBudgetFragment" />
        <action
            android:id="@+id/action_budgetsFragment_to_budgetDetailFragment"
            app:destination="@id/budgetDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/createBudgetFragment"
        android:name="com.example.lifeledger.CreateBudgetFragment"
        android:label="Create Budget"
        tools:layout="@layout/fragment_create_budget" />

    <fragment
        android:id="@+id/budgetDetailFragment"
        android:name="com.example.lifeledger.BudgetDetailFragment"
        android:label="Budget Detail"
        tools:layout="@layout/fragment_budget_detail" />

    <fragment
        android:id="@+id/goalsFragment"
        android:name="com.example.lifeledger.GoalsFragment"
        android:label="Goals"
        tools:layout="@layout/fragment_goals">
        <action
            android:id="@+id/action_goalsFragment_to_goalDetailFragment"
            app:destination="@id/goalDetailFragment" />
        <action
            android:id="@+id/action_goalsFragment_to_addGoalFragment"
            app:destination="@id/addGoalFragment" />
    </fragment>

    <fragment
        android:id="@+id/addGoalFragment"
        android:name="com.example.lifeledger.AddGoalFragment"
        android:label="Add Goal"
        tools:layout="@layout/fragment_add_goal" />

    <fragment
        android:id="@+id/goalDetailFragment"
        android:name="com.example.lifeledger.GoalDetailFragment"
        android:label="Goal Detail"
        tools:layout="@layout/fragment_goal_detail">
        <action
            android:id="@+id/action_goalDetailFragment_to_goalHistoryFragment"
            app:destination="@id/goalHistoryFragment" />
    </fragment>

    <fragment
        android:id="@+id/goalHistoryFragment"
        android:name="com.example.lifeledger.GoalHistoryFragment"
        android:label="Goal History"
        tools:layout="@layout/fragment_goal_history" />

    <fragment
        android:id="@+id/monthlyReportFragment"
        android:name="com.example.lifeledger.MonthlyReportFragment"
        android:label="Monthly Report"
        tools:layout="@layout/fragment_monthly_report" />

    <!-- Lifestyle -->
    <fragment
        android:id="@+id/nav_lifestyle"
        android:name="com.example.lifeledger.LifestyleFragment"
        android:label="Lifestyle"
        tools:layout="@layout/fragment_lifestyle">
        <action
            android:id="@+id/action_lifestyleFragment_to_habitsFragment"
            app:destination="@id/habitsFragment" />
        <action
            android:id="@+id/action_lifestyleFragment_to_tasksFragment"
            app:destination="@id/tasksFragment" />
        <action
            android:id="@+id/action_lifestyleFragment_to_calendarFragment"
            app:destination="@id/calendarFragment" />
        <action
            android:id="@+id/action_lifestyleFragment_to_healthFragment"
            app:destination="@id/nav_health" />
        <action
            android:id="@+id/action_lifestyleFragment_to_routinesFragment"
            app:destination="@id/routinesFragment" />
        <action
            android:id="@+id/action_lifestyleFragment_to_streaksFragment"
            app:destination="@id/streaksFragment" />
    </fragment>

    <fragment
        android:id="@+id/habitsFragment"
        android:name="com.example.lifeledger.HabitsFragment"
        android:label="Habits"
        tools:layout="@layout/fragment_habits">
        <action
            android:id="@+id/action_habitsFragment_to_createHabitFragment"
            app:destination="@id/createHabitFragment" />
        <action
            android:id="@+id/action_habitsFragment_to_habitDetailFragment"
            app:destination="@id/habitDetailFragment" />

    </fragment>

    <fragment
        android:id="@+id/createHabitFragment"
        android:name="com.example.lifeledger.CreateHabitFragment"
        android:label="Create Habit"
        tools:layout="@layout/fragment_create_habit" />

    <fragment
        android:id="@+id/habitDetailFragment"
        android:name="com.example.lifeledger.HabitDetailFragment"
        android:label="Habit Detail"
        tools:layout="@layout/fragment_habit_detail">
    <argument
        android:name="habitId"
        app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/tasksFragment"
        android:name="com.example.lifeledger.TasksFragment"
        android:label="Tasks"
        tools:layout="@layout/fragment_tasks">
        <action
            android:id="@+id/action_tasksFragment_to_addTaskFragment"
            app:destination="@id/addTaskFragment" />
        <action
            android:id="@+id/action_tasksFragment_to_taskDetailFragment"
            app:destination="@id/taskDetailFragment" />
    </fragment>
    
    <fragment
        android:id="@+id/addTaskFragment"
        android:name="com.example.lifeledger.AddTaskFragment"
        android:label="Add Task"
        tools:layout="@layout/fragment_task_add" />

    <fragment
        android:id="@+id/taskDetailFragment"
        android:name="com.example.lifeledger.TaskDetailFragment"
        android:label="Task Detail"
        tools:layout="@layout/fragment_task_detail" />

    <fragment
        android:id="@+id/calendarFragment"
        android:name="com.example.lifeledger.CalendarFragment"
        android:label="Calendar"
        tools:layout="@layout/fragment_calendar" />

    <fragment
        android:id="@+id/nav_health"
        android:name="com.example.lifeledger.HealthFragment"
        android:label="Health"
        tools:layout="@layout/fragment_health">
        <action
            android:id="@+id/action_healthFragment_to_addHealthFragment"
            app:destination="@id/addHealthFragment" />
    </fragment>

    <fragment
        android:id="@+id/addHealthFragment"
        android:name="com.example.lifeledger.AddHealthFragment"
        android:label="Log Health"
        tools:layout="@layout/fragment_add_health" />

    <fragment
        android:id="@+id/routinesFragment"
        android:name="com.example.lifeledger.RoutinesFragment"
        android:label="Routines"
        tools:layout="@layout/fragment_routines" />

    <fragment
        android:id="@+id/streaksFragment"
        android:name="com.example.lifeledger.StreaksFragment"
        android:label="Streaks"
        tools:layout="@layout/fragment_streaks" />


    <!-- Social -->
    <fragment
        android:id="@+id/activityFeedFragment"
        android:name="com.example.lifeledger.ActivityFeedFragment"
        android:label="Activity Feed"
        tools:layout="@layout/fragment_activity_feed" />

    <!-- Profile -->
    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.lifeledger.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profileFragment_to_personalizationFragment"
            app:destination="@id/personalizationFragment" />
        <action
            android:id="@+id/action_profileFragment_to_securityFragment"
            app:destination="@id/securityFragment" />
        <action
            android:id="@+id/action_profileFragment_to_connectedAppsFragment"
            app:destination="@id/connectedAppsFragment" />
        <action
            android:id="@+id/action_profileFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_profileFragment_to_helpFragment"
            app:destination="@id/helpFragment" />
        <action
            android:id="@+id/action_profileFragment_to_premiumFragment"
            app:destination="@id/premiumFragment" />
        <action
            android:id="@+id/action_profileFragment_to_feedbackFragment"
            app:destination="@id/feedbackFragment" />
    </fragment>

    <fragment
        android:id="@+id/personalizationFragment"
        android:name="com.example.lifeledger.PersonalizationFragment"
        android:label="Personalization"
        tools:layout="@layout/fragment_personalization" />

    <fragment
        android:id="@+id/securityFragment"
        android:name="com.example.lifeledger.SecurityFragment"
        android:label="Security"
        tools:layout="@layout/fragment_security" />

    <fragment
        android:id="@+id/connectedAppsFragment"
        android:name="com.example.lifeledger.ConnectedAppsFragment"
        android:label="Connected Apps"
        tools:layout="@layout/fragment_connected_apps" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.lifeledger.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/helpFragment"
        android:name="com.example.lifeledger.HelpFragment"
        android:label="Help"
        tools:layout="@layout/fragment_help" />

    <fragment
        android:id="@+id/premiumFragment"
        android:name="com.example.lifeledger.PremiumFragment"
        android:label="Premium"
        tools:layout="@layout/fragment_premium">
        <action
            android:id="@+id/action_premiumFragment_to_paymentFragment"
            app:destination="@id/paymentFragment" />
    </fragment>

    <fragment
        android:id="@+id/feedbackFragment"
        android:name="com.example.lifeledger.FeedbackFragment"
        android:label="Feedback"
        tools:layout="@layout/fragment_feedback" />
        
    <fragment
        android:id="@+id/paymentFragment"
        android:name="com.example.lifeledger.PaymentFragment"
        android:label="Payment"
        tools:layout="@layout/fragment_payment"/>

</navigation>
