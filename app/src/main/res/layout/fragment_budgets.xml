<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray_bg"
    android:padding="20dp">

    <!-- Top Toolbar (Removed Extra Header) -->
    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- BACK BUTTON -->

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_button"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/black" />

        <!-- TITLE -->

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="Budgets"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iv_back"
            app:layout_constraintTop_toTopOf="@id/iv_back"
            app:layout_constraintBottom_toBottomOf="@id/iv_back" />

        <!-- MONTH SELECTOR -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layout_month_selector"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E8E8E8"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iv_back"
            app:layout_constraintBottom_toBottomOf="@id/iv_back">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:id="@+id/btn_prev_month"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_media_previous"
                    app:tint="@color/black"/>

                <TextView
                    android:id="@+id/tv_selected_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="14dp"
                    android:text="May 2026"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/btn_next_month"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_media_next"
                    app:tint="@color/black"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Total Budget Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_total_budget"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/header_layout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_budget_card_gradient"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_total_budget_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/total_budget"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:letterSpacing="0.05"
                android:textAllCaps="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_total_budget_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/total_budget_val"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_total_budget_label" />

            <!-- Piggy Bank Icon -->
            <ImageView
                android:layout_width="84dp"
                android:layout_height="71dp"
                android:backgroundTint="#33FFFFFF"
                android:padding="10dp"
                android:src="@drawable/ic_ruppee"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tv_spent_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/spent_val"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:layout_marginTop="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_total_budget_val" />

            <TextView
                android:id="@+id/tv_remaining_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/remaining_val"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_total_budget_val" />
            <ProgressBar
                android:id="@+id/pb_total_budget"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:max="100"
                android:progress="40"
                android:progressTint="@color/white"
                android:progressBackgroundTint="#33FFFFFF"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/tv_spent_val"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_category_budgets"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/category_budgets"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/card_total_budget"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_budget"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="+ Add"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="13sp"
        android:paddingHorizontal="14dp"
        app:cornerRadius="20dp"
        android:backgroundTint="@color/brand_purple"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="@id/tv_category_budgets"
        app:layout_constraintBottom_toBottomOf="@id/tv_category_budgets"
        app:layout_constraintEnd_toEndOf="parent"/>
    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/pb_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_category_budgets"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone"/>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_category_budgets"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_wallet"
            app:tint="@color/gray" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No budgets for this month"
            android:textColor="@color/gray"
            android:textSize="16sp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Budgets RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_budgets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_budget_category"
        app:layout_constraintTop_toBottomOf="@id/tv_category_budgets"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
