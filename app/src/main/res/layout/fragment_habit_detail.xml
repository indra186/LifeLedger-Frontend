<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top Bar -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back"
                app:tint="@color/black" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <ImageView
                android:id="@+id/btn_delete"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_delete"
                app:tint="@color/expense_red"/>
        </LinearLayout>

        <!-- Habit Card -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/iv_icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_social_button"
                    android:padding="16dp"
                    android:src="@drawable/ic_habit_water"
                    app:tint="@color/brand_purple" />

                <TextView
                    android:id="@+id/tv_habit_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Drink Water"
                    android:textColor="@color/black"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Stay hydrated daily"
                    android:textColor="@color/gray"
                    android:textSize="15sp" />

                <!-- Streak -->

                <TextView
                    android:id="@+id/tv_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="🔥 5 Day Streak"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Goal -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Goal:"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_goal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="3 times/day" />
                </LinearLayout>

                <!-- Reminder -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reminder:"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_reminder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="8:00 PM" />
                </LinearLayout>

                <!-- Frequency -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Frequency:"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_frequency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Daily" />
                </LinearLayout>

                <!-- Custom Days -->

                <TextView
                    android:id="@+id/tv_custom_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Mon, Wed, Fri"
                    android:textColor="@color/brand_purple"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Status -->

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Completed Today"
                    android:textColor="#4CAF50"
                    android:textStyle="bold"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/tv_week_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Loading weekly history..."
                    android:textColor="@color/gray"
                    android:textSize="13sp"/>
                <LinearLayout
                    android:id="@+id/layout_week_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:weightSum="7"
                    android:paddingHorizontal="12dp"
                    android:layout_marginTop="20dp"
                    android:visibility="gone">

                    <!-- MON -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"

                        android:layout_weight="1"
                        >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mon"
                            android:textSize="12sp"
                            android:textColor="@color/gray"/>

                        <TextView
                            android:id="@+id/tv_mon"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/white"
                            android:background="@drawable/bg_dot_neutral"/>
                    </LinearLayout>

                    <!-- TUE -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"

                        android:layout_weight="1"
                        >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tue"
                            android:textSize="12sp"
                            android:textColor="@color/gray"/>

                        <TextView
                            android:id="@+id/tv_tue"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/white"
                            android:background="@drawable/bg_dot_neutral"/>
                    </LinearLayout>

                    <!-- WED -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"

                        android:layout_weight="1"
                        >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wed"
                            android:textSize="12sp"
                            android:textColor="@color/gray"/>

                        <TextView
                            android:id="@+id/tv_wed"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/white"
                            android:background="@drawable/bg_dot_neutral"/>
                    </LinearLayout>

                    <!-- THU -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"

                        android:layout_weight="1"
                        >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thu"
                            android:textSize="12sp"
                            android:textColor="@color/gray"/>

                        <TextView
                            android:id="@+id/tv_thu"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/white"
                            android:background="@drawable/bg_dot_neutral"/>
                    </LinearLayout>

                    <!-- FRI -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"

                        android:layout_weight="1"
                        >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fri"
                            android:textSize="12sp"
                            android:textColor="@color/gray"/>

                        <TextView
                            android:id="@+id/tv_fri"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/white"
                            android:background="@drawable/bg_dot_neutral"/>
                    </LinearLayout>

                    <!-- SAT -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"

                        android:layout_weight="1"
                        >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sat"
                            android:textSize="12sp"
                            android:textColor="@color/gray"/>

                        <TextView
                            android:id="@+id/tv_sat"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/white"
                            android:background="@drawable/bg_dot_neutral"/>
                    </LinearLayout>

                    <!-- SUN -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"

                        android:layout_weight="1"
                        >

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sun"
                            android:textSize="12sp"
                            android:textColor="@color/gray"/>

                        <TextView
                            android:id="@+id/tv_sun"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/white"
                            android:background="@drawable/bg_dot_neutral"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>