<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- HEADER -->

    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_back"
        app:tint="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create Habit"
        android:textColor="@color/black"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/iv_back"
        app:layout_constraintBottom_toBottomOf="@id/iv_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CONTENT -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/iv_back"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- HABIT NAME -->

            <TextView
                android:id="@+id/tv_habit_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Habit Name"
                android:textColor="@color/gray"
                android:textSize="14sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/et_habit_name"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text"
                android:hint="Morning workout"
                android:paddingHorizontal="16dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray"
                app:layout_constraintTop_toBottomOf="@id/tv_habit_name"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- DESCRIPTION -->

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Description"
                android:textColor="@color/gray"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/et_habit_name"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/et_description"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text"
                android:gravity="top"
                android:hint="Describe your habit..."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray"
                app:layout_constraintTop_toBottomOf="@id/tv_description"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- ICONS -->

            <TextView
                android:id="@+id/tv_choose_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Choose Icon"
                android:textColor="@color/gray"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/et_description"
                app:layout_constraintStart_toStartOf="parent"/>

            <LinearLayout
                android:id="@+id/icon_grid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/tv_choose_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- ROW 1 -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="5">

                    <ImageView
                        android:id="@+id/icon_fitness"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/light_purple_bg"
                        android:padding="14dp"
                        android:src="@drawable/ic_habit_fitness"
                         />

                    <ImageView
                        android:id="@+id/icon_reading"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/light_purple_bg"
                        android:padding="14dp"
                        android:src="@drawable/ic_habit_reading"
                         />

                    <ImageView
                        android:id="@+id/icon_art"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/light_purple_bg"
                        android:padding="14dp"
                        android:src="@drawable/ic_habit_art"
                         />

                    <ImageView
                        android:id="@+id/icon_journal"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/light_purple_bg"
                        android:padding="14dp"
                        android:src="@drawable/ic_habit_journal"
                         />

                    <ImageView
                        android:id="@+id/icon_music"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/light_purple_bg"
                        android:padding="14dp"
                        android:src="@drawable/ic_habit_music"
                         />

                </LinearLayout>

                <!-- ROW 2 -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:weightSum="5">

                    <ImageView
                        android:id="@+id/icon_nature"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/light_purple_bg"
                        android:padding="14dp"
                        android:src="@drawable/ic_habit_nature"
                         />

                    <ImageView
                        android:id="@+id/icon_running"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/light_purple_bg"
                        android:padding="14dp"
                        android:src="@drawable/ic_habit_running"
                         />

                    <ImageView
                        android:id="@+id/icon_water"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/light_purple_bg"
                        android:padding="14dp"
                        android:src="@drawable/ic_habit_water"
                         />

                    <ImageView
                        android:id="@+id/icon_work"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/light_purple_bg"
                        android:padding="14dp"
                        android:src="@drawable/ic_habit_work"
                         />

                    <ImageView
                        android:id="@+id/icon_alarm"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_margin="4dp"
                        android:background="@drawable/bg_social_button"
                        android:backgroundTint="@color/light_purple_bg"
                        android:padding="14dp"
                        android:src="@drawable/ic_habit_alarm"
                         />

                </LinearLayout>

            </LinearLayout>

            <!-- FREQUENCY -->

            <TextView
                android:id="@+id/tv_frequency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Frequency"
                android:textColor="@color/gray"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/icon_grid"
                app:layout_constraintStart_toStartOf="parent"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_frequency"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tv_frequency"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <AutoCompleteTextView
                    android:id="@+id/dropdown_frequency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select frequency"
                    android:inputType="none"/>


            </com.google.android.material.textfield.TextInputLayout>
            <LinearLayout
                android:id="@+id/layout_custom_days"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/layout_frequency">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Days"
                    android:textColor="@color/gray"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cb_mon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mon"/>

                    <CheckBox
                        android:id="@+id/cb_tue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tue"/>

                    <CheckBox
                        android:id="@+id/cb_wed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wed"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cb_thu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thu"/>

                    <CheckBox
                        android:id="@+id/cb_fri"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fri"/>

                    <CheckBox
                        android:id="@+id/cb_sat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sat"/>

                    <CheckBox
                        android:id="@+id/cb_sun"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sun"/>
                </LinearLayout>

            </LinearLayout>
            <!-- GOAL -->

            <TextView
                android:id="@+id/tv_goal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Goal"
                android:textColor="@color/gray"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/layout_custom_days"
                app:layout_constraintStart_toStartOf="parent"/>

            <LinearLayout
                android:id="@+id/goal_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tv_goal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <EditText
                    android:id="@+id/et_goal"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edit_text"
                    android:hint="3"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"/>

                <AutoCompleteTextView
                    android:id="@+id/dropdown_goal_unit"
                    android:layout_width="120dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_edit_text"
                    android:hint="Unit"
                    android:paddingHorizontal="16dp"/>

            </LinearLayout>

            <!-- REMINDER -->

            <TextView
                android:id="@+id/tv_reminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Reminder"
                android:textColor="@color/gray"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/goal_container"
                app:layout_constraintStart_toStartOf="parent"/>

            <EditText
                android:id="@+id/et_reminder"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edit_text"
                android:clickable="true"
                android:focusable="false"
                android:hint="Select reminder time"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_reminder"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- REMINDER CHECKBOX -->

<!--            <CheckBox-->
<!--                android:id="@+id/cb_reminder"-->
<!--                android:layout_width="24dp"-->
<!--                android:layout_height="24dp"-->
<!--                android:layout_marginTop="20dp"-->
<!--                app:layout_constraintTop_toBottomOf="@id/et_reminder"-->
<!--                app:layout_constraintStart_toStartOf="parent"/>-->

<!--            <TextView-->
<!--                android:id="@+id/tv_reminder_title"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_marginStart="12dp"-->
<!--                android:text="Send daily reminders"-->
<!--                android:textColor="@color/black"-->
<!--                android:textStyle="bold"-->
<!--                android:textSize="14sp"-->
<!--                app:layout_constraintStart_toEndOf="@id/cb_reminder"-->
<!--                app:layout_constraintTop_toTopOf="@id/cb_reminder"/>-->

<!--            <TextView-->
<!--                android:id="@+id/tv_reminder_desc"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="Get notified to complete your habit"-->
<!--                android:textColor="@color/gray"-->
<!--                android:textSize="12sp"-->
<!--                app:layout_constraintTop_toBottomOf="@id/tv_reminder_title"-->
<!--                app:layout_constraintStart_toStartOf="@id/tv_reminder_title"/>-->

            <!-- BUTTON -->

            <Button
                android:id="@+id/btn_create_habit"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/brand_purple"
                android:text="Create Habit"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                app:layout_constraintTop_toBottomOf="@id/et_reminder"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>